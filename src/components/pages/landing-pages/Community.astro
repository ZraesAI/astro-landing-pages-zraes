---
import { Send, Users, ArrowRight } from "lucide-astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
	class="relative py-24 bg-[#0A0A0A] overflow-hidden"
	id="community-section"
>
	<!-- Dynamic Background grid -->
	<div
		class="absolute inset-0 opacity-[0.03]"
		style="background-image: linear-gradient(#D4AF37 1px, transparent 1px), linear-gradient(90deg, #D4AF37 1px, transparent 1px); background-size: 40px 40px;"
	>
	</div>

	<div class="relative container mx-auto px-6 max-w-6xl">
		<div class="flex flex-col items-center text-center mb-16">
			<div
				class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#D4AF37]/30 bg-[#D4AF37]/5 mb-6"
			>
				<Users class="w-4 h-4 text-[#D4AF37]" />
				<span class="text-xs text-[#D4AF37] font-bold uppercase tracking-widest"
					>{t("community.badge")}</span
				>
			</div>
			<h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
				{t("community.title")}
				<span
					class="text-transparent bg-clip-text bg-gradient-to-r from-[#D4AF37] via-[#FFD700] to-[#D4AF37]"
					>{t("community.title.highlight")}</span
				>
			</h2>
			<p class="text-[#B8B8B8] text-lg max-w-2xl mx-auto">
				{t("community.desc")}
			</p>
		</div>

		<div class="grid md:grid-cols-2 gap-8 lg:gap-12 max-w-4xl mx-auto">
			<!-- Channel Card -->
			<a
				href="https://t.me/ZraesAI"
				target="_blank"
				rel="noopener noreferrer"
				class="group relative rounded-3xl p-8 bg-[#141414]/80 border border-white/5 hover:border-[#D4AF37]/40 transition-all duration-500 overflow-hidden flex flex-col items-center text-center"
			>
				<div
					class="absolute inset-0 transition-opacity duration-500 opacity-0 group-hover:opacity-100"
					style="background: radial-gradient(circle at center, rgba(212,175,55,0.1) 0%, transparent 70%)"
				>
				</div>
				<div
					class="w-16 h-16 rounded-2xl bg-[#D4AF37]/10 flex items-center justify-center mb-6 border border-[#D4AF37]/20 group-hover:scale-110 transition-transform duration-500"
				>
					<Send class="w-8 h-8 text-[#D4AF37]" />
				</div>
				<h3
					class="text-2xl font-bold text-white mb-3 group-hover:text-[#D4AF37] transition-colors"
				>
					{t("community.channel.title")}
				</h3>
				<p class="text-[#B8B8B8] text-sm mb-8 flex-grow">
					{t("community.channel.desc")}
				</p>
				<div
					class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-[#D4AF37]"
				>
					{t("community.btn.join")}
					<ArrowRight
						class="w-4 h-4 group-hover:translate-x-1 transition-transform"
					/>
				</div>
			</a>

			<!-- Group Card -->
			<a
				href="https://t.me/ZraesAIDiscuss"
				target="_blank"
				rel="noopener noreferrer"
				class="group relative rounded-3xl p-8 bg-[#141414]/80 border border-white/5 hover:border-[#D4AF37]/40 transition-all duration-500 overflow-hidden flex flex-col items-center text-center"
			>
				<div
					class="absolute inset-0 transition-opacity duration-500 opacity-0 group-hover:opacity-100"
					style="background: radial-gradient(circle at center, rgba(212,175,55,0.1) 0%, transparent 70%)"
				>
				</div>
				<div
					class="w-16 h-16 rounded-2xl bg-[#D4AF37]/10 flex items-center justify-center mb-6 border border-[#D4AF37]/20 group-hover:scale-110 transition-transform duration-500"
				>
					<Users class="w-8 h-8 text-[#D4AF37]" />
				</div>
				<h3
					class="text-2xl font-bold text-white mb-3 group-hover:text-[#D4AF37] transition-colors"
				>
					{t("community.group.title")}
				</h3>
				<p class="text-[#B8B8B8] text-sm mb-8 flex-grow">
					{t("community.group.desc")}
				</p>
				<div
					class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-[#D4AF37]"
				>
					{t("community.btn.join")}
					<ArrowRight
						class="w-4 h-4 group-hover:translate-x-1 transition-transform"
					/>
				</div>
			</a>
		</div>
	</div>
</section>
